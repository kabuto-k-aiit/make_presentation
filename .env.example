# Supabase データベース設定
# Project URLからProject Reference IDを取得
# 例: https://xxxxxxxxxxxxx.supabase.co → xxxxxxxxxxxxx
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Upstash Redis 設定
# Details タブから以下の情報を取得:
REDIS_URL=rediss://:[YOUR-PASSWORD]@[YOUR-ENDPOINT]:6380
REDIS_HOST=[YOUR-ENDPOINT]
REDIS_PORT=6380
REDIS_PASSWORD=[YOUR-PASSWORD]

# アプリケーション設定
SECRET_KEY=your-super-secret-key-here-make-it-long-and-random
REFRESH_SECRET_KEY=your-refresh-secret-key-here-also-long-and-random
GEMINI_API_KEY=your-google-gemini-api-key

# 管理者アカウント設定
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-admin-password-here
ADMIN_EMAIL=admin@example.com

# 開発用設定
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
ENVIRONMENT=development